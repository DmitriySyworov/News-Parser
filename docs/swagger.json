                        "name": "uuid",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/app_news-parser_internal_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/definitions/app_news-parser_internal_model.ArticleArchive"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "validation errors:\" | `uuid` - article_uuid must be 36 characters long",
                        "schema": {
                            "$ref": "#/definitions/app_news-parser_internal_response.Response"
                        }
                    },
                    "404": {
                        "description": "not found:\" | `not_found_articles` - article not found",
                        "schema": {
                            "$ref": "#/definitions/app_news-parser_internal_response.Response"
                        }
                    }
                }
            }
        },
        "/api/v1/article/archive/{category}": {
            "get": {
                "description": "get archive articles by category",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "article_default"
                ],
                "summary": "get archive articles",
                "parameters": [
                    {
                        "type": "string",
                        "description": "food, politics, sport, cloth, electronics, the following categories are valid, as well as all to get all entries",
                        "name": "category",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "offset default 0",
                        "name": "offset",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "limit default 50",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "date must be YYYY-MM-DD",
                        "name": "date",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/app_news-parser_internal_response.Response"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/definitions/internal_article_default.ResponseCategoryArchive"
                                            }
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "validation errors:\" | `offset` - the offset must be a positive integer | `limit` - the limit must be a positive integer | `category` - this category of articles does not exist | `date` - the date format must be YYYY-MM-DD",
                        "schema": {
                            "$ref": "#/definitions/app_news-parser_internal_response.Response"
                        }
                    },
                    "404": {
                        "description": "not found:\" | `not_found_articles` - article not found",
                        "schema": {
                            "$ref": "#/definitions/app_news-parser_internal_response.Response"
                        }
                    }
                }
            }
        },
